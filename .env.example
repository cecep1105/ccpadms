# ---- Core ----
DEBUG=True
SECRET_KEY=django-insecure-ganti-dengan-random-string-panjang
ALLOWED_HOSTS=localhost,127.0.0.1

# WAJIB diisi kalau deploy di belakang nginx/reverse proxy dengan domain
# publik -- tanpa ini, LOGIN & SEMUA FORM POST gagal dengan error "CSRF
# verification failed... Origin checking failed - https://domain-anda does
# not match any trusted origins." Isi LENGKAP dengan skema https://, pisah
# koma kalau lebih dari satu domain. Contoh:
#   CSRF_TRUSTED_ORIGINS=https://absensi.perusahaan.com,https://www.perusahaan.com
CSRF_TRUSTED_ORIGINS=

# Set True di produksi kalau server sudah HTTPS (via nginx atau langsung).
# Biarkan False untuk development lokal (http://localhost biasa).
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
TIME_ZONE=Asia/Jakarta
# False = timestamp mentah dari device fingerprint dianggap sudah waktu lokal
# apa adanya (rekomendasi untuk integrasi iclock -- lihat catatan di README
# bagian Attendance Recap). Ubah ke True HANYA kalau proses yang menulis
# transaksi ke database sudah benar-benar menyimpan dalam UTC.
USE_TZ=False

# Redis dipakai sebagai channel layer WebSocket (console real-time Active
# Device, lihat iclock/consumers.py & iclock/ws_utils.py). Perlu Redis server
# jalan di alamat ini (default port Redis standar).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# mclock -- Mobile Attendance (monitoring data absensi mobile dari MSSQL
# eksternal). Setup: 1) `python manage.py generate_mclock_key` -> isi
# MCLOCK_ENCRYPTION_KEY, 2) `python manage.py encrypt_mssql_password` -> isi
# MCLOCK_MSSQL_PASSWORD_ENCRYPTED. JANGAN PERNAH isi password plaintext di sini.
MCLOCK_ENCRYPTION_KEY=
MCLOCK_MSSQL_HOST=
MCLOCK_MSSQL_PORT=1433
MCLOCK_MSSQL_DATABASE=
MCLOCK_MSSQL_USERNAME=
MCLOCK_MSSQL_PASSWORD_ENCRYPTED=
# Default '7.0' -- SQL Server 2008 butuh ini eksplisit, kalau tidak koneksi
# gagal ("Adaptive Server connection failed"). Bisa di-override per-source
# di mclock/sources.py kalau ada server lain yang butuh versi beda.
MCLOCK_MSSQL_TDS_VERSION=7.0

# Celery -- default-nya reuse Redis yang sama dengan Channels di atas (DB
# index beda, /1) -- BIARKAN 2 baris di bawah ini di-comment (jangan diisi
# string kosong) supaya default dinamis di settings.py yang dipakai. Cuma
# perlu diisi kalau mau pakai broker/Redis instance yang BENAR-BENAR beda.
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# HANYA utk development/testing tanpa worker Celery sungguhan -- WAJIB
# False (atau hapus baris ini) di produksi.
CELERY_TASK_ALWAYS_EAGER=False

# ---- Database (MySQL) ----
DB_ENGINE=django.db.backends.mysql
DB_NAME=nuxt_backend
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
# Untuk dev cepat tanpa MySQL, bisa pakai sqlite:
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# ---- LDAP / Active Directory ----
# Untuk Active Directory: pakai sAMAccountName, BUKAN uid (AD tidak punya atribut uid).
AUTH_LDAP_SERVER_URI=ldap://ldap.example.com:389
AUTH_LDAP_BIND_DN=cn=admin,dc=example,dc=com
AUTH_LDAP_BIND_PASSWORD=service_account_password
AUTH_LDAP_BASE_DN=ou=users,dc=example,dc=com
AUTH_LDAP_USER_SEARCH_FILTER=(uid={username})
AUTH_LDAP_USE_SSL=False
AUTH_LDAP_CONNECT_TIMEOUT=5
AUTH_LDAP_ATTR_EMAIL=mail
AUTH_LDAP_ATTR_FIRST_NAME=givenName
AUTH_LDAP_ATTR_LAST_NAME=sn

# Contoh khusus Active Directory (uncomment & sesuaikan):
# AUTH_LDAP_SERVER_URI=ldap://dc01.corp.local:389
# AUTH_LDAP_BIND_DN=CN=Service Account,OU=ServiceAccounts,DC=corp,DC=local
# (atau format UPN: AUTH_LDAP_BIND_DN=svc_ldap@corp.local)
# AUTH_LDAP_BASE_DN=DC=corp,DC=local
# AUTH_LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

# ---- CORS (Nuxt frontend) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- JWT ----
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
