# Copy file ini jadi `.env` (SATU FOLDER dgn docker-compose.yml, di
# docker/.env) -- docker-compose otomatis baca file ini.
#
#   cp docker/env.docker.example docker/.env

# ---- WAJIB diisi ----
SECRET_KEY=ganti-dengan-random-string-panjang-django
NEXTAUTH_SECRET=ganti-juga-generate-pakai-openssl-rand--base64-32
DB_PASSWORD=ganti-password-mysql-root

# ---- Django ----
DEBUG=False
# ALLOWED_HOSTS/CSRF_TRUSTED_ORIGINS/CORS_ALLOWED_ORIGINS -- BEDA dari
# NEXT_PUBLIC_*/DJANGO_INTERNAL_URL di bawah (yg soal FRONTEND nyambung
# ke API): ini validasi DJANGO SENDIRI thd Host header request yg masuk
# (proteksi keamanan bawaan Django, TIDAK otomatis ikut relatif spt
# frontend) -- TETAP WAJIB tambahkan tiap IP/domain yg dipakai akses
# (pisah koma), mis. kalau diakses juga lewat IP LAN:
#   ALLOWED_HOSTS=localhost,127.0.0.1,172.16.10.36
#   CSRF_TRUSTED_ORIGINS=http://localhost,http://172.16.10.36:8036
#   CORS_ALLOWED_ORIGINS=http://localhost,http://172.16.10.36:8036
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
TIME_ZONE=Asia/Jakarta
USE_TZ=False
DB_NAME=ccpadms
CORS_ALLOWED_ORIGINS=http://localhost
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- LDAP (opsional, kosongkan kalau tidak pakai) ----
AUTH_LDAP_SERVER_URI=
AUTH_LDAP_BIND_DN=
AUTH_LDAP_BIND_PASSWORD=
AUTH_LDAP_BASE_DN=
AUTH_LDAP_USER_SEARCH_FILTER=(uid={username})
AUTH_LDAP_USE_SSL=False

# ---- mclock / MSSQL eksternal (opsional, kosongkan kalau tidak pakai) ----
# Encryption key & password TERENKRIPSI -- generate PAKAI CONTAINER ini
# sendiri stlh `docker compose up -d`, JANGAN isi password plaintext:
#   docker compose exec django-web python manage.py generate_mclock_key
#   docker compose exec django-web python manage.py encrypt_mssql_password
MCLOCK_ENCRYPTION_KEY=
MCLOCK_MSSQL_HOST=
MCLOCK_MSSQL_PORT=1433
MCLOCK_MSSQL_DATABASE=
MCLOCK_MSSQL_USERNAME=
MCLOCK_MSSQL_PASSWORD_ENCRYPTED=
MCLOCK_MSSQL_TDS_VERSION=7.0

# ---- Next.js ----
# NEXT_PUBLIC_API_BASE_URL & NEXT_PUBLIC_WS_BASE_URL SENGAJA DIKOSONGKAN --
# kode frontend SEKARANG otomatis pakai path relatif (HTTP) & origin
# browser SAAT ITU (WebSocket), ikut IP/domain APA PUN yang dipakai user
# akses (via nginx yang menyatukan Next.js & Django jadi 1 origin) --
# TIDAK PERLU diisi/rebuild lagi tiap ganti cara akses (localhost, IP LAN,
# domain lain, dst). CUMA isi salah satu/keduanya kalau MEMANG butuh API
# di origin BERBEDA dari halaman Next.js-nya sendiri (skenario tidak
# disatukan nginx) -- lihat komentar di docker-compose.yml.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_BASE_URL=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXTAUTH_URL: fallback/default sisi SERVER Next.js -- dgn trustHost=true
# (lib/auth.ts) NextAuth SEBENARNYA ikut Host header request yg BENERAN
# masuk (nginx sudah teruskan itu dgn benar), tapi TETAP isi ini sbg nilai
# default yang masuk akal (dipakai kalau trustHost tidak bisa deteksi,
# jarang terjadi).
NEXTAUTH_URL=http://localhost
